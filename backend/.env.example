DATABASE_URL="postgresql://postgres:postgres@localhost:5432/workforce?schema=public"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-or-publishable-key"
# Optional. Only set this if your project still verifies JWTs with a shared secret.
SUPABASE_JWT_SECRET=""
CLIENT_WEB_URL="http://localhost:5173"
APP_DOMAIN="http://localhost:5173"
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"
EMPLOYEE_PIN_SECRET="replace-with-a-long-random-secret"
DOCUSEAL_API_URL="https://api.docuseal.com"
DOCUSEAL_API_KEY="your-docuseal-api-key"
DOCUSEAL_EMBED_HOST="https://docuseal.com"
DOCUSEAL_ADMIN_EMAIL="docuseal-api-key-owner@example.com"
DOCUSEAL_WEBHOOK_SECRET="your-docuseal-webhook-secret"
# Public backend origin that DocuSeal can reach, for example your ngrok URL without a trailing slash.
DOCUMENT_UPLOAD_PUBLIC_BASE_URL="https://your-ngrok-url.ngrok-free.app"
PORT="4000"
