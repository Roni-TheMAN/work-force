  durationMinutes Int?             @map("duration_minutes")
  source          String
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  shiftSession    TimeShiftSession @relation(fields: [shiftSessionId], references: [id], onDelete: Cascade)

  @@index([shiftSessionId, startedAt])
  @@map("shift_break_segments")
}

/// Audit trail of manual edits that preserve raw punches while capturing before/after shift state.
model TimeAdjustment {
  id               String           @id @default(uuid()) @db.Uuid
  shiftSessionId   String           @map("shift_session_id") @db.Uuid
