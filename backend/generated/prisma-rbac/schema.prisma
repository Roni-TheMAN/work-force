}

/// Configurable overtime rules that can be applied org-wide or overridden per property over time.
model OvertimePolicy {
  id                    String                   @id @default(uuid()) @db.Uuid
  organizationId        String                   @map("organization_id") @db.Uuid
  propertyId            String?                  @map("property_id") @db.Uuid
  name                  String
  status                String
  ot1Multiplier         Decimal                  @map("ot1_multiplier") @db.Decimal(6, 3)
  ot2Multiplier         Decimal                  @map("ot2_multiplier") @db.Decimal(6, 3)
  ot1DailyAfterMinutes  Int?                     @map("ot1_daily_after_minutes")
  ot2DailyAfterMinutes  Int?                     @map("ot2_daily_after_minutes")
  ot1WeeklyAfterMinutes Int?                     @map("ot1_weekly_after_minutes")
  ot2WeeklyAfterMinutes Int?                     @map("ot2_weekly_after_minutes")
  rulesJson             Json?                    @map("rules_json")
  effectiveFrom         DateTime                 @map("effective_from") @db.Timestamptz(6)
  effectiveTo           DateTime?                @map("effective_to") @db.Timestamptz(6)
  createdAt             DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property              Property?                @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  payRates              EmployeePayRate[]
  payrollSettings       PropertyPayrollSetting[] @relation("PropertyPayrollSettingDefaultOvertimePolicy")

  @@unique([id, organizationId])
  @@index([organizationId, effectiveFrom])
  @@index([propertyId, effectiveFrom])
  @@index([status])
  @@map("overtime_policies")
}

