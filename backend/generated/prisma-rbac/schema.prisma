  replacesPunches   TimePunch[]       @relation("TimePunchReplacement")
  createdByUser     User?             @relation("TimePunchCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  clockInShift      TimeShiftSession? @relation("ShiftClockInPunch")
  clockOutShift     TimeShiftSession? @relation("ShiftClockOutPunch")

  @@unique([id, organizationId, propertyId, employeeId])
  @@index([organizationId, businessDate])
  @@index([propertyId, businessDate])
  @@index([employeeId, occurredAt])
  @@index([propertyDeviceId])
  @@index([createdByUserId])
  @@index([clientEventId])
  @@index([status])
  @@map("time_punches")
}

/// Normalized work sessions derived from immutable punches for payroll and labor costing.
model TimeShiftSession {
  id              String              @id @default(uuid()) @db.Uuid
  organizationId  String              @map("organization_id") @db.Uuid
  propertyId      String              @map("property_id") @db.Uuid
  employeeId      String              @map("employee_id") @db.Uuid
  clockInPunchId  String              @unique @map("clock_in_punch_id") @db.Uuid
  clockOutPunchId String?             @unique @map("clock_out_punch_id") @db.Uuid
  startedAt       DateTime            @map("started_at") @db.Timestamptz(6)
  autoCloseAt     DateTime            @map("auto_close_at") @db.Timestamptz(6)
  endedAt         DateTime?           @map("ended_at") @db.Timestamptz(6)
  businessDate    DateTime            @map("business_date") @db.Date
  entryMode       String              @default("punch") @map("entry_mode")
  status          String
  totalMinutes    Int?                @map("total_minutes")
  breakMinutes    Int                 @default(0) @map("break_minutes")
  payableMinutes  Int?                @map("payable_minutes")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property        Property            @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  employee        Employee            @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  clockInPunch    TimePunch           @relation("ShiftClockInPunch", fields: [clockInPunchId], references: [id], onDelete: Restrict)
  clockOutPunch   TimePunch?          @relation("ShiftClockOutPunch", fields: [clockOutPunchId], references: [id], onDelete: Restrict)
  breakSegments   ShiftBreakSegment[]
  adjustments     TimeAdjustment[]

  @@unique([id, organizationId, propertyId, employeeId])
  @@index([organizationId, businessDate])
  @@index([propertyId, businessDate])
  @@index([employeeId, startedAt])
  @@index([status, autoCloseAt])
  @@index([status])
  @@map("time_shift_sessions")
}

/// Break segments attached to a normalized shift session instead of loose punch math.
model ShiftBreakSegment {
  id              String           @id @default(uuid()) @db.Uuid
  shiftSessionId  String           @map("shift_session_id") @db.Uuid
  breakType       String           @map("break_type")
