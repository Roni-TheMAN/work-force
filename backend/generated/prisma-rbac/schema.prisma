/// One payroll calculation run for a pay period, allowing audit-friendly reruns over the same period.
model PayrollRun {
  id                       String                      @id @default(uuid()) @db.Uuid
  organizationId           String                      @map("organization_id") @db.Uuid
  propertyId               String                      @map("property_id") @db.Uuid
  payrollPeriodId          String                      @map("payroll_period_id") @db.Uuid
  requestedByUserId        String                      @map("requested_by_user_id") @db.Uuid
  version                  Int                         @default(1)
  status                   String
  startedAt                DateTime?                   @map("started_at") @db.Timestamptz(6)
  completedAt              DateTime?                   @map("completed_at") @db.Timestamptz(6)
  finalizedAt              DateTime?                   @map("finalized_at") @db.Timestamptz(6)
  finalizedByUserId        String?                     @map("finalized_by_user_id") @db.Uuid
  supersededByPayrollRunId String?                     @map("superseded_by_payroll_run_id") @db.Uuid
  notes                    String?
  createdAt                DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  organization             Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property                 Property                    @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  payrollPeriod            PayrollPeriod               @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  requestedByUser          User                        @relation("PayrollRunRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  finalizedByUser          User?                       @relation("PayrollRunFinalizedByUser", fields: [finalizedByUserId], references: [id], onDelete: SetNull)
  supersededByPayrollRun   PayrollRun?                 @relation("PayrollRunSupersededBy", fields: [supersededByPayrollRunId], references: [id], onDelete: SetNull)
  supersededPayrollRuns    PayrollRun[]                @relation("PayrollRunSupersededBy")
  employeeSummaries        PayrollRunEmployeeSummary[]
  shiftSnapshots           PayrollRunShiftSnapshot[]
  batchRuns                PayrollBatchRun[]

  @@unique([payrollPeriodId, propertyId, version])
  @@index([organizationId, createdAt])
  @@index([propertyId, createdAt])
  @@index([payrollPeriodId])
  @@index([requestedByUserId])
  @@index([finalizedByUserId])
  @@index([supersededByPayrollRunId])
  @@index([status])
  @@map("payroll_runs")
}

/// Org-level payroll totals per employee with a frozen rate snapshot for reruns and exports.
model PayrollRunEmployeeSummary {
  id                 String                        @id @default(uuid()) @db.Uuid
  payrollRunId       String                        @map("payroll_run_id") @db.Uuid
  employeeId         String                        @map("employee_id") @db.Uuid
  approvalStatus     String                        @default("pending") @map("approval_status")
  approvedAt         DateTime?                     @map("approved_at") @db.Timestamptz(6)
  approvedByUserId   String?                       @map("approved_by_user_id") @db.Uuid
  approvalNote       String?                       @map("approval_note")
  totalMinutes       Int                           @map("total_minutes")
  regularMinutes     Int                           @map("regular_minutes")
  overtime1Minutes   Int                           @map("overtime1_minutes")
  overtime2Minutes   Int                           @map("overtime2_minutes")
  breakMinutes       Int                           @map("break_minutes")
  payableMinutes     Int                           @map("payable_minutes")
  regularPayCents    BigInt                        @map("regular_pay_cents")
  overtime1PayCents  BigInt                        @map("overtime1_pay_cents")
  overtime2PayCents  BigInt                        @map("overtime2_pay_cents")
  grossPayCents      BigInt                        @map("gross_pay_cents")
  rateSnapshot       Json                          @map("rate_snapshot")
  createdAt          DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  payrollRun         PayrollRun                    @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee           Employee                      @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  approvedByUser     User?                         @relation("PayrollRunEmployeeSummaryApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  propertyBreakdowns PayrollRunPropertyBreakdown[]

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
  @@index([approvalStatus])
  @@index([approvedByUserId])
  @@map("payroll_run_employee_summaries")
}

/// Frozen shift-level detail for one payroll run so finalized reports do not depend on live shift mutations.
model PayrollRunShiftSnapshot {
  id                  String     @id @default(uuid()) @db.Uuid
  payrollRunId        String     @map("payroll_run_id") @db.Uuid
  shiftSessionId      String     @map("shift_session_id") @db.Uuid
  employeeId          String     @map("employee_id") @db.Uuid
  employeeName        String     @map("employee_name")
  actualStartedAt     DateTime?  @map("actual_started_at") @db.Timestamptz(6)
  actualEndedAt       DateTime?  @map("actual_ended_at") @db.Timestamptz(6)
  startedAt           DateTime   @map("started_at") @db.Timestamptz(6)
  endedAt             DateTime?  @map("ended_at") @db.Timestamptz(6)
  businessDate        DateTime   @map("business_date") @db.Date
  weekStartDate       DateTime?  @map("week_start_date") @db.Date
  weekEndDate         DateTime?  @map("week_end_date") @db.Date
  totalMinutes        Int        @map("total_minutes")
  breakMinutes        Int        @map("break_minutes")
  payableMinutes      Int        @map("payable_minutes")
  regularMinutes      Int?       @map("regular_minutes")
  overtime1Minutes    Int?       @map("overtime1_minutes")
  overtime2Minutes    Int?       @map("overtime2_minutes")
  estimatedGrossCents BigInt?    @map("estimated_gross_cents")
  departmentLabel     String?    @map("department_label")
  punchInfo           String?    @map("punch_info")
  source              String
  entryMode           String     @map("entry_mode")
  shiftStatus         String     @map("shift_status")
  isManual            Boolean    @default(false) @map("is_manual")
  isEdited            Boolean    @default(false) @map("is_edited")
  isAutoClosed        Boolean    @default(false) @map("is_auto_closed")
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  payrollRun          PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, shiftSessionId])
  @@index([payrollRunId, employeeId])
  @@map("payroll_run_shift_snapshots")
}

/// Property-level labor and gross-pay breakdown within an org-wide employee payroll summary.
model PayrollRunPropertyBreakdown {
  id                          String                    @id @default(uuid()) @db.Uuid
  payrollRunEmployeeSummaryId String                    @map("payroll_run_employee_summary_id") @db.Uuid
  propertyId                  String                    @map("property_id") @db.Uuid
  totalMinutes                Int                       @map("total_minutes")
  regularMinutes              Int                       @map("regular_minutes")
  overtime1Minutes            Int                       @map("overtime1_minutes")
  overtime2Minutes            Int                       @map("overtime2_minutes")
  grossPayCents               BigInt                    @map("gross_pay_cents")
  createdAt                   DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  payrollRunEmployeeSummary   PayrollRunEmployeeSummary @relation(fields: [payrollRunEmployeeSummaryId], references: [id], onDelete: Cascade)
  property                    Property                  @relation(fields: [propertyId], references: [id], onDelete: Restrict)

  @@unique([payrollRunEmployeeSummaryId, propertyId])
  @@index([propertyId])
  @@map("payroll_run_property_breakdowns")
}

/// Org-wide wrapper for pulling payroll across multiple property calendars as of one date.
model PayrollBatch {
  id                String            @id @default(uuid()) @db.Uuid
  organizationId    String            @map("organization_id") @db.Uuid
  requestedByUserId String            @map("requested_by_user_id") @db.Uuid
  asOfDate          DateTime          @map("as_of_date") @db.Date
  status            String
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedByUser   User              @relation("PayrollBatchRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  batchRuns         PayrollBatchRun[]

  @@index([organizationId, asOfDate])
  @@index([requestedByUserId])
  @@index([status])
  @@map("payroll_batches")
}

/// Links an org-wide payroll batch to the individual payroll runs it pulled together.
model PayrollBatchRun {
  id             String       @id @default(uuid()) @db.Uuid
  payrollBatchId String       @map("payroll_batch_id") @db.Uuid
  payrollRunId   String       @map("payroll_run_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  payrollBatch   PayrollBatch @relation(fields: [payrollBatchId], references: [id], onDelete: Cascade)
  payrollRun     PayrollRun   @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@unique([payrollBatchId, payrollRunId])
  @@index([payrollRunId])
  @@map("payroll_batch_runs")
}

/// Property-level daily labor rollups for dashboards so reads do not scan raw punches every time.
model PropertyLaborDailyMetric {
  id                   String       @id @default(uuid()) @db.Uuid
  organizationId       String       @map("organization_id") @db.Uuid
  propertyId           String       @map("property_id") @db.Uuid
  metricDate           DateTime     @map("metric_date") @db.Date
  employeesWorkedCount Int          @map("employees_worked_count")
  shiftsCount          Int          @map("shifts_count")
  openShiftsCount      Int          @map("open_shifts_count")
  totalMinutes         Int          @map("total_minutes")
  regularMinutes       Int          @map("regular_minutes")
  overtime1Minutes     Int          @map("overtime1_minutes")
  overtime2Minutes     Int          @map("overtime2_minutes")
  grossLaborCents      BigInt       @map("gross_labor_cents")
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property             Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, metricDate])
  @@index([organizationId, metricDate])
  @@map("property_labor_daily_metrics")
}

/// Organization-level daily labor rollups for consolidated dashboards and payroll analytics.
model OrganizationLaborDailyMetric {
  id                       String       @id @default(uuid()) @db.Uuid
  organizationId           String       @map("organization_id") @db.Uuid
  metricDate               DateTime     @map("metric_date") @db.Date
  propertiesReportingCount Int          @map("properties_reporting_count")
  employeesWorkedCount     Int          @map("employees_worked_count")
  shiftsCount              Int          @map("shifts_count")
  openShiftsCount          Int          @map("open_shifts_count")
  totalMinutes             Int          @map("total_minutes")
  regularMinutes           Int          @map("regular_minutes")
  overtime1Minutes         Int          @map("overtime1_minutes")
  overtime2Minutes         Int          @map("overtime2_minutes")
  grossLaborCents          BigInt       @map("gross_labor_cents")
  createdAt                DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, metricDate])
  @@map("organization_labor_daily_metrics")
}
