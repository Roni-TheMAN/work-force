generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-rbac"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                       @id @db.Uuid
  email                       String                       @unique
  fullName                    String?                      @map("full_name")
  phone                       String?
  avatarUrl                   String?                      @map("avatar_url")
  lastActiveOrganizationId    String?                      @map("last_active_organization_id") @db.Uuid
  createdAt                   DateTime                     @default(now()) @map("created_at")
  updatedAt                   DateTime                     @updatedAt @map("updated_at")
  lastActiveOrganization      Organization?                @relation("LastActiveOrganization", fields: [lastActiveOrganizationId], references: [id])
  ownedOrganizations          Organization[]               @relation("OrganizationOwner")
  organizationMemberships     OrganizationMember[]         @relation("OrganizationMemberUser")
  organizationInvites         OrganizationMember[]         @relation("OrganizationMemberInviter")
  propertyRoles               PropertyUserRole[]
  employee                    Employee?
  createdTimePunches          TimePunch[]                  @relation("TimePunchCreatedByUser")
  timeAdjustments             TimeAdjustment[]             @relation("TimeAdjustmentAdjustedByUser")
  requestedPayrollRuns        PayrollRun[]                 @relation("PayrollRunRequestedByUser")
  finalizedPayrollRuns        PayrollRun[]                 @relation("PayrollRunFinalizedByUser")
  requestedPayrollBatches     PayrollBatch[]               @relation("PayrollBatchRequestedByUser")
  approvedPayrollSummaries    PayrollRunEmployeeSummary[]  @relation("PayrollRunEmployeeSummaryApprovedByUser")
  employeePinsLastSet         Employee[]                   @relation("EmployeePinLastSetByUser")
  employeePinEvents           EmployeePinEvent[]           @relation("EmployeePinEventPerformedByUser")
  propertyDevicePairingTokens PropertyDevicePairingToken[] @relation("PropertyDevicePairingTokenCreatedByUser")
  publishedSchedules          Schedule[]                   @relation("SchedulePublishedByUser")
  createdScheduleTemplates    ScheduleTemplate[]           @relation("ScheduleTemplateCreatedByUser")
  updatedScheduleTemplates    ScheduleTemplate[]           @relation("ScheduleTemplateUpdatedByUser")
  createdShifts               Shift[]                      @relation("ShiftCreatedByUser")
  updatedShifts               Shift[]                      @relation("ShiftUpdatedByUser")
  requestedDocumentEnvelopes  DocumentEnvelope[]           @relation("DocumentEnvelopeRequestedByUser")
  documentEvents              DocumentEvent[]              @relation("DocumentEventActor")

  @@map("users")
}

model Organization {
  id                          String                         @id @default(uuid()) @db.Uuid
  slug                        String                         @unique
  name                        String
  legalName                   String?                        @map("legal_name")
  timezone                    String
  status                      String
  ownerUserId                 String                         @map("owner_user_id") @db.Uuid
  stripeCustomerId            String?                        @unique @map("stripe_customer_id")
  createdAt                   DateTime                       @default(now()) @map("created_at")
  updatedAt                   DateTime                       @updatedAt @map("updated_at")
  archivedAt                  DateTime?                      @map("archived_at")
  ownerUser                   User                           @relation("OrganizationOwner", fields: [ownerUserId], references: [id])
  lastActiveUsers             User[]                         @relation("LastActiveOrganization")
  members                     OrganizationMember[]
  roles                       OrganizationRole[]
  properties                  Property[]
  employees                   Employee[]
  subscriptions               OrganizationSubscription[]
  entitlements                OrganizationEntitlement[]
  timePunches                 TimePunch[]
  shiftSessions               TimeShiftSession[]
  timeAdjustments             TimeAdjustment[]
  overtimePolicies            OvertimePolicy[]
  employeePayRates            EmployeePayRate[]
  payrollCalendars            PayrollCalendar[]
  payrollPeriods              PayrollPeriod[]
  payrollRuns                 PayrollRun[]
  payrollBatches              PayrollBatch[]
  propertyMetrics             PropertyLaborDailyMetric[]
  laborMetrics                OrganizationLaborDailyMetric[]
  employeePinEvents           EmployeePinEvent[]
  propertyDevicePairingTokens PropertyDevicePairingToken[]
  schedules                   Schedule[]
  scheduleTemplates           ScheduleTemplate[]
  scheduledShifts             Shift[]
  scheduleTemplateShifts      ScheduleTemplateShift[]
  documentTemplates           DocumentTemplate[]
  documentEnvelopes           DocumentEnvelope[]
  documentRecipients          DocumentRecipient[]
  signedDocuments             SignedDocument[]
  documentEvents              DocumentEvent[]

  @@map("organizations")
}

model BillingCatalogItem {
  id                String                         @id @default(uuid()) @db.Uuid
  code              String                         @unique
  kind              String
  name              String
  description       String?
  stripeProductId   String                         @unique @map("stripe_product_id")
  active            Boolean                        @default(true)
  createdAt         DateTime                       @default(now()) @map("created_at")
  updatedAt         DateTime                       @updatedAt @map("updated_at")
  prices            BillingPrice[]
  subscriptionItems OrganizationSubscriptionItem[]
  entitlements      OrganizationEntitlement[]      @relation("EntitlementSourceCatalogItem")

  @@map("billing_catalog_items")
}

model BillingPrice {
  id                String             @id @default(uuid()) @db.Uuid
  catalogItemId     String             @map("catalog_item_id") @db.Uuid
  stripePriceId     String             @unique @map("stripe_price_id")
  currency          String
  unitAmountCents   BigInt             @map("unit_amount_cents")
  billingType       String             @map("billing_type")
  recurringInterval String?            @map("recurring_interval")
  intervalCount     Int?               @map("interval_count")
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  catalogItem       BillingCatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@index([catalogItemId])
  @@map("billing_prices")
}

model OrganizationSubscription {
  id                     String                         @id @default(uuid()) @db.Uuid
  organizationId         String                         @map("organization_id") @db.Uuid
  stripeCustomerId       String                         @map("stripe_customer_id")
  stripeSubscriptionId   String                         @unique @map("stripe_subscription_id")
  status                 String
  collectionMethod       String?                        @map("collection_method")
  defaultPaymentMethodId String?                        @map("default_payment_method_id")
  cancelAtPeriodEnd      Boolean                        @default(false) @map("cancel_at_period_end")
  currentPeriodStart     DateTime?                      @map("current_period_start")
  currentPeriodEnd       DateTime?                      @map("current_period_end")
  trialStart             DateTime?                      @map("trial_start")
  trialEnd               DateTime?                      @map("trial_end")
  canceledAt             DateTime?                      @map("canceled_at")
  endedAt                DateTime?                      @map("ended_at")
  latestInvoiceId        String?                        @map("latest_invoice_id")
  checkoutSessionId      String?                        @map("checkout_session_id")
  createdAt              DateTime                       @default(now()) @map("created_at")
  updatedAt              DateTime                       @updatedAt @map("updated_at")
  organization           Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items                  OrganizationSubscriptionItem[]

  @@index([organizationId])
  @@index([checkoutSessionId])
  @@map("organization_subscriptions")
}

model OrganizationSubscriptionItem {
  id                         String                    @id @default(uuid()) @db.Uuid
  organizationSubscriptionId String                    @map("organization_subscription_id") @db.Uuid
  catalogItemId              String                    @map("catalog_item_id") @db.Uuid
  stripeSubscriptionItemId   String                    @unique @map("stripe_subscription_item_id")
  stripePriceId              String                    @map("stripe_price_id")
  quantity                   Int
  metadata                   Json                      @default("{}")
  createdAt                  DateTime                  @default(now()) @map("created_at")
  endedAt                    DateTime?                 @map("ended_at")
  organizationSubscription   OrganizationSubscription  @relation(fields: [organizationSubscriptionId], references: [id], onDelete: Cascade)
  catalogItem                BillingCatalogItem        @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)
  entitlements               OrganizationEntitlement[] @relation("EntitlementSourceSubscriptionItem")

  @@index([organizationSubscriptionId])
  @@index([catalogItemId])
  @@map("organization_subscription_items")
}

model OrganizationEntitlement {
  id                       String                        @id @default(uuid()) @db.Uuid
  organizationId           String                        @map("organization_id") @db.Uuid
  sourceCatalogItemId      String?                       @map("source_catalog_item_id") @db.Uuid
  sourceSubscriptionItemId String?                       @map("source_subscription_item_id") @db.Uuid
  key                      String
  value                    Json
  grantedBy                String                        @map("granted_by")
  createdAt                DateTime                      @default(now()) @map("created_at")
  updatedAt                DateTime                      @updatedAt @map("updated_at")
  organization             Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceCatalogItem        BillingCatalogItem?           @relation("EntitlementSourceCatalogItem", fields: [sourceCatalogItemId], references: [id], onDelete: SetNull)
  sourceSubscriptionItem   OrganizationSubscriptionItem? @relation("EntitlementSourceSubscriptionItem", fields: [sourceSubscriptionItemId], references: [id], onDelete: SetNull)

  @@unique([organizationId, key])
  @@index([sourceCatalogItemId])
  @@index([sourceSubscriptionItemId])
  @@map("organization_entitlements")
}

model StripeWebhookEvent {
  id               String    @id @default(uuid()) @db.Uuid
  stripeEventId    String    @unique @map("stripe_event_id")
  eventType        String    @map("event_type")
  apiVersion       String?   @map("api_version")
  payload          Json
  receivedAt       DateTime  @default(now()) @map("received_at")
  processedAt      DateTime? @map("processed_at")
  processingStatus String    @map("processing_status")
  errorMessage     String?   @map("error_message")

  @@index([processingStatus])
  @@map("stripe_webhook_events")
}

model OrganizationRole {
  id                String                       @id @default(uuid()) @db.Uuid
  organizationId    String                       @map("organization_id") @db.Uuid
  name              String
  description       String?
  isSystem          Boolean                      @default(false) @map("is_system")
  isDefault         Boolean                      @default(false) @map("is_default")
  organization      Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions       OrganizationRolePermission[]
  members           OrganizationMember[]
  propertyUserRoles PropertyUserRole[]
  createdAt         DateTime                     @default(now()) @map("created_at")
  updatedAt         DateTime                     @updatedAt @map("updated_at")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("organization_roles")
}

model OrganizationRolePermission {
  id        String           @id @default(uuid()) @db.Uuid
  roleId    String           @map("role_id") @db.Uuid
  key       String
  role      OrganizationRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now()) @map("created_at")

  @@unique([roleId, key])
  @@index([roleId])
  @@map("organization_role_permissions")
}

model OrganizationMember {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String           @map("organization_id") @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  roleId          String           @map("role_id") @db.Uuid
  status          String
  invitedEmail    String?          @map("invited_email")
  invitedByUserId String?          @map("invited_by_user_id") @db.Uuid
  joinedAt        DateTime?        @map("joined_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User             @relation("OrganizationMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  role            OrganizationRole @relation(fields: [roleId], references: [id])
  invitedByUser   User?            @relation("OrganizationMemberInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([roleId])
  @@index([userId])
  @@map("organization_members")
}

model Property {
  id                     String                        @id @default(uuid()) @db.Uuid
  organizationId         String                        @map("organization_id") @db.Uuid
  name                   String
  code                   String?
  timezone               String
  addressLine1           String?                       @map("address_line1")
  addressLine2           String?                       @map("address_line2")
  city                   String?
  stateRegion            String?                       @map("state_region")
  postalCode             String?                       @map("postal_code")
  countryCode            String?                       @map("country_code")
  status                 String
  createdAt              DateTime                      @default(now()) @map("created_at")
  updatedAt              DateTime                      @updatedAt @map("updated_at")
  organization           Organization                  @relation(fields: [organizationId], references: [id])
  userRoles              PropertyUserRole[]
  employeeAssignments    EmployeePropertyAssignment[]
  propertyDevices        PropertyDevice[]
  timePunches            TimePunch[]
  shiftSessions          TimeShiftSession[]
  timeAdjustments        TimeAdjustment[]
  overtimePolicies       OvertimePolicy[]
  employeePayRates       EmployeePayRate[]
  payrollSettings        PropertyPayrollSetting[]
  payrollRuns            PayrollRun[]
  payrollBreakdowns      PayrollRunPropertyBreakdown[]
  laborMetrics           PropertyLaborDailyMetric[]
  devicePairingTokens    PropertyDevicePairingToken[]
  schedules              Schedule[]
  scheduleTemplates      ScheduleTemplate[]
  scheduledShifts        Shift[]
  scheduleTemplateShifts ScheduleTemplateShift[]
  documentRecipients     DocumentRecipient[]

  @@unique([id, organizationId])
  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("properties")
}

model PropertyUserRole {
  id         String            @id @default(uuid()) @db.Uuid
  propertyId String            @map("property_id") @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  roleId     String?           @map("role_id") @db.Uuid
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  property   Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       OrganizationRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([propertyId, userId])
  @@index([userId])
  @@index([propertyId])
  @@map("property_user_roles")
}

model Employee {
  id                     String                       @id @default(uuid()) @db.Uuid
  organizationId         String                       @map("organization_id") @db.Uuid
  userId                 String?                      @unique @map("user_id") @db.Uuid
  firstName              String                       @map("first_name")
  lastName               String                       @map("last_name")
  email                  String?
  phone                  String?
  employeeCode           String?                      @map("employee_code")
  pinHash                String?                      @map("pin_hash")
  pinLookupKey           String?                      @map("pin_lookup_key")
  pinCiphertext          String?                      @map("pin_ciphertext")
  pinLastSetAt           DateTime?                    @map("pin_last_set_at") @db.Timestamptz(6)
  pinLastSetByUserId     String?                      @map("pin_last_set_by_user_id") @db.Uuid
  employmentStatus       String                       @map("employment_status")
  hireDate               DateTime?                    @map("hire_date")
  terminatedAt           DateTime?                    @map("terminated_at")
  createdAt              DateTime                     @default(now()) @map("created_at")
  updatedAt              DateTime                     @updatedAt @map("updated_at")
  organization           Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                   User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  propertyAssignments    EmployeePropertyAssignment[]
  timePunches            TimePunch[]
  shiftSessions          TimeShiftSession[]
  timeAdjustments        TimeAdjustment[]
  payRates               EmployeePayRate[]
  payrollSummaries       PayrollRunEmployeeSummary[]
  pinLastSetByUser       User?                        @relation("EmployeePinLastSetByUser", fields: [pinLastSetByUserId], references: [id], onDelete: SetNull)
  pinEvents              EmployeePinEvent[]
  scheduledShifts        Shift[]
  scheduleTemplateShifts ScheduleTemplateShift[]
  documentRecipients     DocumentRecipient[]
  signedDocuments        SignedDocument[]

  @@unique([id, organizationId])
  @@unique([organizationId, employeeCode])
  @@unique([organizationId, userId])
  @@unique([organizationId, pinLookupKey])
  @@index([organizationId])
  @@index([pinLastSetByUserId])
  @@map("employees")
}

model EmployeePropertyAssignment {
  id         String    @id @default(uuid()) @db.Uuid
  employeeId String    @map("employee_id") @db.Uuid
  propertyId String    @map("property_id") @db.Uuid
  isPrimary  Boolean   @default(false) @map("is_primary")
  activeFrom DateTime? @map("active_from")
  activeTo   DateTime? @map("active_to")
  createdAt  DateTime  @default(now()) @map("created_at")
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([employeeId, propertyId])
  @@index([propertyId])
  @@map("employee_property_assignments")
}

model Schedule {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @map("organization_id") @db.Uuid
  propertyId        String       @map("property_id") @db.Uuid
  weekStartDate     DateTime     @map("week_start_date") @db.Date
  status            String
  publishedAt       DateTime?    @map("published_at") @db.Timestamptz(6)
  publishedByUserId String?      @map("published_by_user_id") @db.Uuid
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property          Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  publishedByUser   User?        @relation("SchedulePublishedByUser", fields: [publishedByUserId], references: [id], onDelete: SetNull)
  shifts            Shift[]

  @@unique([propertyId, weekStartDate])
  @@index([organizationId, weekStartDate])
  @@index([propertyId, status])
  @@index([publishedByUserId])
  @@map("schedules")
}

model Shift {
  id              String       @id @default(uuid()) @db.Uuid
  scheduleId      String       @map("schedule_id") @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  propertyId      String       @map("property_id") @db.Uuid
  employeeId      String?      @map("employee_id") @db.Uuid
  positionLabel   String?      @map("position_label")
  date            DateTime     @db.Date
  startAt         DateTime     @map("start_at") @db.Timestamptz(6)
  endAt           DateTime     @map("end_at") @db.Timestamptz(6)
  breakMinutes    Int          @default(0) @map("break_minutes")
  status          String
  notes           String?
  createdByUserId String       @map("created_by_user_id") @db.Uuid
  updatedByUserId String       @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  schedule        Schedule     @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property        Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  employee        Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  createdByUser   User         @relation("ShiftCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser   User         @relation("ShiftUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@index([scheduleId, date])
  @@index([organizationId, date])
  @@index([propertyId, date])
  @@index([employeeId, startAt, endAt])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("shifts")
}

model ScheduleTemplate {
  id              String                  @id @default(uuid()) @db.Uuid
  organizationId  String                  @map("organization_id") @db.Uuid
  propertyId      String                  @map("property_id") @db.Uuid
  slotIndex       Int                     @map("slot_index")
  name            String
  createdByUserId String                  @map("created_by_user_id") @db.Uuid
  updatedByUserId String                  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property        Property                @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdByUser   User                    @relation("ScheduleTemplateCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser   User                    @relation("ScheduleTemplateUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: Restrict)
  shifts          ScheduleTemplateShift[]

  @@unique([propertyId, slotIndex])
  @@index([organizationId, propertyId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("schedule_templates")
}

model ScheduleTemplateShift {
  id             String           @id @default(uuid()) @db.Uuid
  templateId     String           @map("template_id") @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  propertyId     String           @map("property_id") @db.Uuid
  employeeId     String?          @map("employee_id") @db.Uuid
  dayIndex       Int              @map("day_index")
  startMinutes   Int              @map("start_minutes")
  endMinutes     Int              @map("end_minutes")
  isOvernight    Boolean          @default(false) @map("is_overnight")
  breakMinutes   Int              @default(0) @map("break_minutes")
  positionLabel  String?          @map("position_label")
  status         String
  notes          String?
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  template       ScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  employee       Employee?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([templateId, dayIndex])
  @@index([organizationId, propertyId, dayIndex])
  @@index([employeeId, dayIndex, startMinutes, endMinutes])
  @@map("schedule_template_shifts")
}

model DocumentTemplate {
  id                  String                  @id @default(uuid()) @db.Uuid
  organizationId      String                  @map("organization_id") @db.Uuid
  systemTemplateId    String?                 @map("system_template_id") @db.Uuid
  docusealTemplateId  String?                 @map("docuseal_template_id")
  externalId          String                  @unique @map("external_id")
  title               String
  description         String?
  category            String
  sourceType          String                  @map("source_type")
  builderStatus       String                  @default("ready") @map("builder_status")
  status              String
  fileUrl             String?                 @map("file_url")
  fileHash            String?                 @map("file_hash")
  sourceFileUrl       String?                 @map("source_file_url")
  sourceFileName      String?                 @map("source_file_name")
  sourceFileMimeType  String?                 @map("source_file_mime_type")
  sourceFileSizeBytes Int?                    @map("source_file_size_bytes")
  createdByUserId     String?                 @map("created_by_user_id") @db.Uuid
  updatedByUserId     String?                 @map("updated_by_user_id") @db.Uuid
  archivedAt          DateTime?               @map("archived_at") @db.Timestamptz(6)
  createdAt           DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization        Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  systemTemplate      SystemDocumentTemplate? @relation(fields: [systemTemplateId], references: [id], onDelete: SetNull)
  envelopeItems       DocumentEnvelopeItem[]
  signedDocuments     SignedDocument[]
  events              DocumentEvent[]

  @@unique([organizationId, docusealTemplateId])
  @@index([organizationId, status])
  @@index([organizationId, category])
  @@index([organizationId, builderStatus])
  @@index([organizationId, sourceType])
  @@index([systemTemplateId])
  @@index([fileHash])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("document_templates")
}

model SystemDocumentTemplate {
  id                 String             @id @default(uuid()) @db.Uuid
  docusealTemplateId String             @unique @map("docuseal_template_id")
  title              String
  description        String?
  category           String
  sourceType         String             @default("system_seeded") @map("source_type")
  status             String             @default("active")
  sourceFileUrl      String?            @map("source_file_url")
  sourceFileName     String?            @map("source_file_name")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  organizationCopies DocumentTemplate[]

  @@index([status])
  @@index([category])
  @@map("system_document_templates")
}

model DocumentEnvelope {
  id                String                 @id @default(uuid()) @db.Uuid
  organizationId    String                 @map("organization_id") @db.Uuid
  purpose           String
  status            String
  requestedByUserId String                 @map("requested_by_user_id") @db.Uuid
  messageSubject    String?                @map("message_subject")
  messageBody       String?                @map("message_body")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedByUser   User                   @relation("DocumentEnvelopeRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  items             DocumentEnvelopeItem[]
  recipients        DocumentRecipient[]
  events            DocumentEvent[]

  @@index([organizationId, createdAt])
