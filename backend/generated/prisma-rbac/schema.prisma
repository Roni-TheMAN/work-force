  payrollCalendarId String          @map("payroll_calendar_id") @db.Uuid
  periodStartDate   DateTime        @map("period_start_date") @db.Date
  periodEndDate     DateTime        @map("period_end_date") @db.Date
  payDate           DateTime?       @map("pay_date") @db.Date
